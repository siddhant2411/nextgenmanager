# Database
DATASOURCE_URL=jdbc:postgresql://localhost:5432/nextgenmanager
DATASOURCE_USERNAME=postgres
DATASOURCE_PASSWORD=your_secure_password

# JWT Authentication
JWT_SECRET=change-this-to-a-64-character-minimum-random-secret-key-for-prod
JWT_ALGORITHM=HS512
JWT_ACCESS_EXPIRATION_MILLIS=900000
JWT_REFRESH_EXPIRATION_MILLIS=604800000
JWT_ISSUER=https://auth.erp.nextgenmanager.com
JWT_AUDIENCE=erp-backend

# MinIO File Storage (S3-compatible)
MINIO_URL=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=nextgenmanager

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# MCP Server (optional)
MCP_SERVER_ENABLED=true
MCP_SERVER_NAME=nextgenmanager-mcp
MCP_SERVER_VERSION=0.1.0
